# Lombok configuration for zarlania-api.

# Stop searching for further lombok.config files in parent directories. Without
# this, a developer's ~/lombok.config could silently change how this project
# compiles, so the same source would build differently on different machines.
config.stopBubbling = true

# --- Banned: annotations that duplicate what records already do ---
#
# CLAUDE.md requires records for immutable data carriers, and a record already
# provides accessors, equals, hashCode and toString. These annotations offer a
# second way to express the same thing on a mutable class, which is both weaker
# and a competing convention. Making them build errors keeps the codebase and
# the written guidance from drifting apart.
#
# Reach for a record instead. If a mutable class genuinely needs an accessor —
# a JPA entity, say — write the method by hand so the choice is visible.
lombok.data.flagUsage = ERROR
lombok.value.flagUsage = ERROR
lombok.getter.flagUsage = ERROR
lombok.setter.flagUsage = ERROR

# --- Also banned ---
#
# @Cleanup predates try-with-resources and hides the resource's lifetime.
lombok.cleanup.flagUsage = ERROR
#
# These swallow or obscure control flow, which CLAUDE.md asks to keep shallow
# and legible: @SneakyThrows defeats checked exceptions, @val/@var hide types
# that the guidance treats as documentation.
lombok.sneakyThrows.flagUsage = ERROR
lombok.val.flagUsage = ERROR
lombok.var.flagUsage = ERROR

# --- Allowed, and why ---
#
# @RequiredArgsConstructor  the concise form of the constructor injection
#                           CLAUDE.md mandates
# @Slf4j                    removes a logger declaration repeated in every class
# @Builder                  worth it once a constructor takes many arguments
# @ToString @EqualsAndHashCode  for classes that cannot be records
#
# Adds @lombok.Generated to generated methods so coverage tools skip them.
# Lombok 1.18.46 already defaults this to true; set explicitly so that the 80%
# JaCoCo gate does not quietly depend on an upstream default.
lombok.addLombokGeneratedAnnotation = true
