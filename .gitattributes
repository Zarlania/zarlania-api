# Normalize line endings on checkin; check out with native endings.
* text=auto eol=lf

# Scripts must keep LF even on Windows checkouts.
*.sh text eol=lf
mvnw text eol=lf

# Windows-only scripts keep CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files — never diff or normalize.
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary

# Collapse generated files in GitHub diffs.
.mvn/** linguist-vendored
